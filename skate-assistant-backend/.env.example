# ─────────────────────────────────────────────────────────────────
# skate-assistant-backend — environment configuration template
# Copy to .env for local dev. Real secrets come from Secret Manager
# in dev/staging/prod (Story 1.1 places empty placeholders; Story 1.2+
# wires the loaders).
# ─────────────────────────────────────────────────────────────────

# Runtime
ENVIRONMENT=local
REGION=us-central1
LOG_LEVEL=INFO
GIT_COMMIT_SHA=unknown

# Database (Story 1.2 fills this in; local-compose maps to the postgres service)
DATABASE_URL=postgresql+asyncpg://assistant:assistant@postgres:5432/assistant

# Redis (Memorystore in cloud — Story 1.13/1.14)
REDIS_URL=redis://redis:6379/0

# Chat SSE tuning (Story 1.5 — defaults match architecture guidance)
# CHAT_TURN_HEARTBEAT_SECONDS=15
# CHAT_TURN_TTL_SECONDS=300

# OpenTelemetry / Cloud Trace
OTEL_SERVICE_NAME=skate-assistant-backend
OTEL_TRACES_EXPORTER=gcp_trace
# Set to console to inspect spans locally without GCP creds
# OTEL_TRACES_EXPORTER=console
GOOGLE_CLOUD_PROJECT=

# Secret Manager references (NOT values — values resolved at runtime)
SECRET_FIREBASE_ADMIN_CREDENTIALS=projects/_/secrets/firebase-admin-credentials/versions/latest
SECRET_ANTHROPIC_API_KEY=projects/_/secrets/anthropic-api-key/versions/latest
SECRET_LANGFUSE_API_KEY=projects/_/secrets/langfuse-api-key/versions/latest
SECRET_ANONYMOUS_JWT_SIGNING=projects/_/secrets/anonymous-jwt-signing-secret/versions/latest

# Firebase (local emulator host — see docker-compose)
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099
FIRESTORE_EMULATOR_HOST=firebase-emulator:8080
